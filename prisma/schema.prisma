// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  description String
  body        String?  // Detailed case study (Markdown/HTML)
  techStack   String[]
  liveUrl     String?
  githubUrl   String?
  imageUrl    String   // Clean CDN path (e.g. "/projects/naturalist.jpg")
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Admin {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model BlogPost {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  slug       String   @unique
  content    String?  // Markdown/HTML content
  coverImage String?  // Header image URL
  excerpt    String?  // Blog post short summary card text
  category   String?  // Article category label (e.g. Announcements, Tech Guide)
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Comment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  blogPostId String   @db.ObjectId
  authorName String
  content    String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Testimonial {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  clientName String
  role       String
  company    String
  quote      String
  avatarUrl  String?  // Optional path to local avatar or Cloudinary asset
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
